class Board {
private:
    static const int BOARD_SIZE = 7;
    vector<unique_ptr<Laivas>> ships; //smart pointer
    set<Coordinate> missedShots;
    set<Coordinate> VisiSuviai;

public:
    Board() {}


    void placeShip(unique_ptr<Laivas> ship) {
        // checkina ar galimas padejimas laivo
        for (const auto& coord : ship->getCoordinates()) {
            if (coord.getX() < 0 || coord.getX() >= BOARD_SIZE ||
                coord.getY() < 0 || coord.getY() >= BOARD_SIZE) {
                throw NetinkamosKoordinates("Laivo koordinates uz lentles ribu.");
            }


            for (const auto& existingShip : ships) {
                if (existingShip->Koordinates(coord)) {
                    throw ShipPlacementException("Laivai vienas ant kito " + coord.toString()); // spausdina ant laivu koordinates, kurios overlappina
                }
            }
        }

        ships.push_back(move(ship));
    }

    // Suvis
    bool receiveShot(const Coordinate& coord) {
        if (coord.getX() < 0 || coord.getX() >= BOARD_SIZE ||
            coord.getY() < 0 || coord.getY() >= BOARD_SIZE) {
            throw NetinkamosKoordinates("Suvio koordinates uz lenteles.");
        }

        // patikrint ar jau sove i sita vieta
        if (VisiSuviai.find(coord) != VisiSuviai.end()) {
            throw GameException("Jau sovete i sia vieta. Bandykite kita.");
        }

        VisiSuviai.insert(coord);

        // patikrinimas pataikymo
        for (auto& ship : ships) {
            if (ship->hit(coord)) { //true/false, bei vieta kur pataike
                return true; //pataikyta
            }
        }

        //nepataikyta
        missedShots.insert(coord);
        return false;
    }

    // patikrint ar visi laivai sunaikinti
    bool allShipsSunk() const {
        for (const auto& ship : ships) {
            if (!ship->Sunk()) {
                return false;
            }
        }
        return !ships.empty();
    }

    // boardo dydis
    static int getBoardSize() {
        return BOARD_SIZE;
    }


    void AtspausdintSavoBoard() const {
        vector<vector<char>> boardView(BOARD_SIZE, vector<char>(BOARD_SIZE, '.')); // boardo vaizdas be nieko tik su "."

        // Mark ships
        for (const auto& ship : ships) {
            for (const auto& coord : ship->getCoordinates()) {
                if (ship->Koordinates(coord)) {
                    if (VisiSuviai.find(coord) != VisiSuviai.end()) {
                        boardView[coord.getX()][coord.getY()] = 'X'; // PATAIKYTAS laivas
                    } else {
                        boardView[coord.getX()][coord.getY()] = 'O'; // laivas
                    }
                }
            }
        }

        for (const auto& coord : missedShots) {
            boardView[coord.getX()][coord.getY()] = '*'; // nepataike
        }

        // stulpeliai
        cout << "  ";
        for (int i = 0; i < BOARD_SIZE; ++i) {
            cout << static_cast<char>('A' + i) << " "; //static_cast, nes saugiau
        }
        cout << endl;

        //skaiciai
        for (int i = 0; i < BOARD_SIZE; ++i) {
            cout << (i + 1);
            if (i < 9) cout << " "; //sulygint 1-10
            for (int j = 0; j < BOARD_SIZE; ++j) {
                cout << boardView[i][j] << " ";
            }
            cout << endl;
        }
    }

    // Priesininko board (hidden ships)
    void AtspausdintpriesininkoBoard() const {

        vector<vector<char>> boardView(BOARD_SIZE, vector<char>(BOARD_SIZE, '.'));//visas boardas


        for (const auto& coord : VisiSuviai) {
            bool Pataikyta = false;
            for (const auto& ship : ships) {
                if (ship->Koordinates(coord)) {
                    boardView[coord.getX()][coord.getY()] = 'X'; // PATAIKE
                    Pataikyta = true;
                    break;
                }
            }
            if (!Pataikyta) {
                boardView[coord.getX()][coord.getY()] = '*'; // Nepataike
            }
        }

        //stulpeliai raides
        cout << "  ";
        for (int i = 0; i < BOARD_SIZE; ++i) {
            cout << static_cast<char>('A' + i) << " ";
        }
        cout << endl;


        for (int i = 0; i < BOARD_SIZE; ++i) {
            cout << (i + 1);
            if (i < 9) cout << " "; //sulygint 1-10
            for (int j = 0; j < BOARD_SIZE; ++j) {
                cout << boardView[i][j] << " ";
            }
            cout << endl;
        }
    }

    // vektorius
    const vector<unique_ptr<Laivas>>& getShips() const {
        return ships;
    }

    // setai
    const set<Coordinate>& getMissedShots() const {
        return missedShots;
    }
};


class Player {
private:
    string name;
    Board board;

public:
    //Konstruktorius
    Player(const string& playerName) : name(playerName) {}

    // zaidejo vardas
    const string& getName() const { return name; }

    // zaidejo visa lentele laivu
    Board& getBoard() { return board; }
    const Board& getBoard() const { return board; }

    void placeShips() {
        cout << "\n" << name << ", pastatykite savo laivus:\n";

        //galima configint nustatymus kaip nori
        LaivoTpasPadet<Karo_laivas>(1);
        LaivoTpasPadet<Kreiseris>(1);
        LaivoTpasPadet<Naikintojas>(1);
        LaivoTpasPadet<Submarinas>(1);

        cout << "\nVisi laivai sekmingai pastatyti!\n";
        board.AtspausdintSavoBoard();
        cout << "\nPaspasukite Enter, norint pratest.";
        cin.ignore(numeric_limits<streamsize>::max(), '\n'); // max simboliu skcius (limits) ENTER paspaudimas

        // pravalo screena
        for (int i = 0; i < 50; ++i) {
            cout << endl;
        }
    }

    // Sablonai
    template <typename TipasLaivo>
    void LaivoTpasPadet(int count) {
        for (int i = 0; i < count; ++i) {
            bool TinkamasPadejimas = false;

            while (!TinkamasPadejimas) {
                board.AtspausdintSavoBoard();

                unique_ptr<Laivas> ship = make_unique<TipasLaivo>(); //unique_ptr<Laivas> - tai tipas, saugantis Laivas*, kuri jis vieninteliu atsakingai istrina.
                cout << "\nDedamas " << ship->getName() << " (Dydis: " << ship->getSize() << ")\n";

                try {
                    Coordinate start = getCoordinateInput("Irasykite laivu koordinates (A1, B3): ");

                    char orientacija;
                    cout << "Irasykite orientacija (H - Horizontaliai, V - Vertikaliai): ";
                    cin >> orientacija;
                    cin.ignore(numeric_limits<streamsize>::max(), '\n'); //didziausias galimas skaicius

                    orientacija = toupper(orientacija);// keicia raide i DIDZIAJA
                    if (orientacija != 'H' && orientacija != 'V') {
                        throw GameException("Bloga orientacija. Irasykite H arba V."); //is naujo leidzia perrasyt laiva
                    }

                    // Generate all coordinates for the ship
                    for (int j = 0; j < ship->getSize(); ++j) {
                        if (orientacija == 'H') {
                            ship->addCoordinate(Coordinate(start.getX(), start.getY() + j));
                        } else {
                            ship->addCoordinate(Coordinate(start.getX() + j, start.getY()));
                        }
                    }

                    // bandyti padet laiva
                    board.placeShip(move(ship));
                    TinkamasPadejimas = true;

                } catch (const GameException& e) {
                    cout << "Klaida: " << e.what() << " Bandykite dar karta.\n";
                }
            }
        }
    }


    Coordinate getCoordinateInput(const string& promptas) {
        string input;

        while (true) {
            cout << promptas; //Iveskite koordinates, kur norite sauti: arba ...
            getline(cin, input);

            // konvertuot i didziasias raides (a1->A1)
            transform(input.begin(), input.end(), input.begin(), ::toupper);

            if (input.length() < 2 || input.length() > 3) {
                cout << "Negaliams formatas. Irasykite raide, tada skaiciu (A1,C3 ir t.t).\n";
                continue;
            }

            char stulpChar = input[0];
            int stulp = stulpChar - 'A';

            // isanalizuot eilutes numeri
            try {
                int eil = stoi(input.substr(1)) - 1; // Convert to 0-based index

                if (stulp < 0 || stulp >= Board::getBoardSize() ||
                    eil < 0 || eil >= Board::getBoardSize()) {
                    cout << "Koordinates isejo is lenteles. Pateikite galimas koordinates.\n";
                    continue;
                }

                return Coordinate(eil, stulp);
            } catch (const exception&) {
                cout << "Negalimas eilutes numeris. Irasykite taisyklinga skaiciu.\n";
            }
        }
    }
};

// zaidimo valdymas visas
class Game {
private:
    Player player1;
    Player player2;
    Player* currentPlayer;
    Player* opponent;
    // panaudojamas map
    map<string, int> gameStats;

public:
    // Konstruktoriai
    Game(const string& p1Name, const string& p2Name)
        : player1(p1Name), player2(p2Name), currentPlayer(&player1), opponent(&player2) {
        gameStats["player1_pataikymai"] = 0;
        gameStats["player1_nepataikymai"] = 0;
        gameStats["player2_pataikymai"] = 0;
        gameStats["player2_nepataikymai"] = 0;
        gameStats["total_ejimai"] = 0;
    }

    // pradet
    void pradet() {
        cout << "=== LAIVU MUSIO Zaidimas ===\n";
        cout << "Zaidejai: " << player1.getName() << " vs " << player2.getName() << "\n\n";

        // stato zaidejai laivus
        player1.placeShips();
        player2.placeShips();
    }

    // pradet zaidima
    void play() {
        pradet();

        while (true) {
            PradetEjima();

            // Patikrinti ar laimejo
            if (opponent->getBoard().allShipsSunk()) {
                cout << "\n" << currentPlayer->getName() << " Laimi Zaidima!\n";

                // galutiniai rez, pavaizduoti stats
                displayGameStats();
                break;
            }

            // apkeist zaidejus (is opponent, i current, ir atvirskciai)
            Player* temp = currentPlayer;
            currentPlayer = opponent;
            opponent = temp;
        }
    }

    // zaidejo ejimai
    void PradetEjima() {
        cout << "\n" << currentPlayer->getName() << " Eile Zaist\n";
        cout << "Tavo Lenta:\n";
        currentPlayer->getBoard().AtspausdintSavoBoard();
        cout << "\nPriesininko Lenta:\n";
        opponent->getBoard().AtspausdintpriesininkoBoard();

        bool validShot = false;
        while (!validShot) {
            try {
                // suvio cords
                Coordinate SautCoord = currentPlayer->getCoordinateInput("Iveskite koordinates, kur norite sauti: ");

                // suvis
                bool isHit = opponent->getBoard().receiveShot(SautCoord);
                validShot = true;

                // updatinimi stats
                gameStats["total_ejimai"]++;
                string ZaidejoKey;
                if (currentPlayer == &player1) {
                    ZaidejoKey = "player1";
                } else {
                    ZaidejoKey = "player2";
                }

                if (isHit) {
                    cout << "PATAIKYTA!\n";
                    gameStats[ZaidejoKey + "_pataikymai"]++;

                    // tikrina ar sunaikintas laivas
                    for (const auto& ship : opponent->getBoard().getShips()) {
                        if (ship->Koordinates(SautCoord) && ship->Sunk()) {
                            cout << "Tu sunaikinai priesininko " << ship->getName() << "!\n";
                        }
                    }
                } else {
                    cout << "Nepataiekei!\n";
                    gameStats[ZaidejoKey + "_nepataikymai"]++;
                }

                // template
                Notification<string> notification(SautCoord .toString(), "Sautas Suvis: ");
                notification.display();

            } catch (const GameException& e) {
                cout << "Klaida: " << e.what() << " Pabandyk dar karta.\n";
            }
        }

        cout << "Paspausk Enter, norint testi...";
        cin.ignore(numeric_limits<streamsize>::max(), '\n'); //max simboliu skaicius


        // praclearina screena
        for (int i = 0; i < 50; ++i) {
            cout << endl;
        }
    }

    // map panaudotas
    void displayGameStats() const {
        cout << "\n=== Zaidimo STATISTIKA ===\n";
        cout << player1.getName() << " Statistika:\n";
        cout << "Pataikymai: " << gameStats.at("player1_pataikymai") << "\n";
        cout << "Nepataikymai: " << gameStats.at("player1_nepataikymai") << "\n";
        cout << "Pataikymo procentas: " << ApskaiciuotProc("player1") << "%\n";
        cout<<"------------------------------------------------------------------------------\n";
        cout<<"------------------------------------------------------------------------------\n";

        cout << player2.getName() << " Statistika:\n";
        cout << "Pataikymai: " << gameStats.at("player2_pataikymai") << "\n";
        cout << "Nepataikymai: " << gameStats.at("player2_nepataikymai") << "\n";
        cout << "Pataikymo procentas: " << ApskaiciuotProc("player2") << "%\n";

        cout << "Isviso ejimai: " << gameStats.at("total_ejimai") << "\n";
    }

    // Calculate hit rate for a player
    double ApskaiciuotProc(const string& player) const {
        int hits = gameStats.at(player + "_pataikymai");
        int misses = gameStats.at(player + "_nepataikymai");
        int total = hits + misses;

        if (total == 0) return 0.0;

        return (double(hits) / total) * 100.0;
    }
};


