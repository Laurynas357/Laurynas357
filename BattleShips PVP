//Notifs, exceptions and so on...
template <typename T>
class Notification {
private:
    T data;
    string message;
public:
    Notification(T d, const string& msg) : data(d), message(msg) {}

    void display() const {
        cout << message << ": " << data << endl;
    }
};


template <>
class Notification<string> {
private:
    string data;
    string message;
public:
    Notification(string d, const string& msg) : data(d), message(msg) {}

    void display() const {
        cout << message << ": " << data << endl;
    }
};

// exceptions
class GameException : public exception {
private:
    string errorMessage;
public:
    GameException(const string& message) : errorMessage(message) {}

    const char* what() const noexcept override {
        return errorMessage.c_str();
    }
};

class NetinkamosKoordinates : public GameException {
public:
    NetinkamosKoordinates(const string& message) : GameException(message) {}
};

class ShipPlacementException : public GameException {
public:
    ShipPlacementException(const string& message) : GameException(message) {}
};

//pozicija lentelej
class Coordinate {
private:
    int x;
    int y;
public:

    Coordinate() : x(0), y(0) {}
    Coordinate(int xPos, int yPos) : x(xPos), y(yPos) {}

    // kopijuoti konstruktoriu
    Coordinate(const Coordinate& kitas) : x(kitas.x), y(kitas.y) {}


    // Operatoriu tikrinimas, kad sortint setuose arba maps(displayGameStats)
        bool operator<(const Coordinate& kitas) const {
        if (x == kitas.x)
            return y < kitas.y;
        return x < kitas.x;
    }

    bool operator==(const Coordinate& kitas) const {
        return x == kitas.x && y == kitas.y;
    }

    // priskkirt operatorius
    Coordinate& operator=(const Coordinate& other) {
        if (this != &other) {
            x = other.x;
            y = other.y;
        }
        return *this;
    }

    int getX() const { return x; }
    int getY() const { return y; }
    void setX(int xPos) { x = xPos; }
    void setY(int yPos) { y = yPos; }

    // konvertavimas i string (lengviau displayint)
    string toString() const {
        char letter = 'A' + y;
        return string(1, letter) + to_string(x + 1);
    }
};


// klases, paveldimumas
class Laivas {
protected:
    int size;
    string name;
    set<Coordinate> coordinates;
    set<Coordinate> hitCoordinates;

public:
    // **Konstruktoriai** (Constructors)
    Laivas(int shipSize, const string& shipName) : size(shipSize), name(shipName) {}

    // Virtualus destruktorius, kad geriau inherintu savybes
    virtual ~Laivas() {}

    // laivo koordinates
    void addCoordinate(const Coordinate& coord) {
        coordinates.insert(coord);
    }

    // tikrinimas laivo koordinaciu
    bool Koordinates(const Coordinate& coord) const {
        return coordinates.find(coord) != coordinates.end();
    }

    // patikrina ar laivas buvo hittintas
    bool hit(const Coordinate& coord) {
        if (Koordinates(coord)) {
            hitCoordinates.insert(coord);
            return true;
        }
        return false;
    }

    // tikrinimas ar sudauzytas laivas
    bool Sunk() const {
        return hitCoordinates.size() == coordinates.size();
    }

    // laivo dydis
    int getSize() const { return size; }

    // vardas laivo
    const string& getName() const { return name; }

    //Polimorfizmas
    virtual string getType() const {
        return "Paprastas laivas";
    }

    // visos koord laivo
    const set<Coordinate>& getCoordinates() const {
        return coordinates;
    }
};

